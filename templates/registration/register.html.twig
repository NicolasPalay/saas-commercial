{% extends 'base.html.twig' %}

{% block title %}Créer un compte{% endblock %}

{% block body %}

<div class="w-50 bg-white rounded shadow p-4 mx-auto mt-5 container">



        <h1 class="fs-3 fw-bold text-center text-dark mb-4">
            Sign Up
        </h1>

        {{ form_start(registrationForm, { attr: { class: 'd-grid gap-4' } }) }}

        {{ form_errors(registrationForm) }}

        {# EMAIL #}
        <div class="position-relative">
            <span class="position-absolute top-50 start-0 translate-middle-y ps-3">
                <i class="bi bi-envelope"></i>
            </span>
            {{ form_widget(registrationForm.email, {
                attr: {
                    class: 'input-ocean',
                    placeholder: 'E-mail'
                }
            }) }}
            {{ form_errors(registrationForm.email) }}
        </div>

        {# PASSWORD #}
        <div class="position-relative">
            <span class="position-absolute top-50 start-0 translate-middle-y ps-3" >
                <i class="bi bi-lock"></i>
            </span>
            {{ form_widget(registrationForm.plainPassword, {
                attr: {
                    class: 'input-ocean',
                    placeholder: 'Password'
                }
            }) }}
            {{ form_errors(registrationForm.plainPassword) }}
        </div>

        {# COMPANY NAME #}
        <div class="position-relative">
            <span class="position-absolute top-50 start-0 translate-middle-y ps-3 ">
                <i class="bi bi-building"></i>
            </span>
            {{ form_widget(registrationForm.name, {
                attr: {
                    class: 'input-ocean',
                    placeholder: 'Name company'
                }
            }) }}
            {{ form_errors(registrationForm.name) }}
        </div>

        <div class="position-relative">
            <span class="position-absolute top-50 start-0 translate-middle-y ps-3">
                <i class="bi bi-building"></i>
            </span>
            {{ form_widget(registrationForm.refDevis, {
                attr: {
                    class: 'input-ocean',
                    placeholder: 'Reference devis'
                }
            }) }}
            {{ form_errors(registrationForm.refDevis) }}
        </div>
        
        <div class="position-relative">
            <span class="position-absolute top-50 start-0 translate-middle-y ps-3">
                <i class="bi bi-building"></i>
            </span>
            {{ form_widget(registrationForm.refFacture, {
                attr: {
                    class: 'input-ocean',
                    placeholder: 'Reference facture'
                }
            }) }}
            {{ form_errors(registrationForm.refFacture) }}
        </div>

        {# TERMS #}
        <div class="form-check small text-secondary">
            {{ form_widget(registrationForm.agreeTerms, {
                attr: {
                    class: 'form-check-input'
                }
            }) }}
            <label class="form-check-label" for="{{ registrationForm.agreeTerms.vars.id }}">
                I read and agree to
                <a href="#" class="">
                    Terms & Conditions
                </a>
            </label>
        </div>

        {# SUBMIT #}
        <button type="submit" class="btn-sand w-100">
            CREATE ACCOUNT
        </button>

        {{ form_end(registrationForm) }}

        <p class="text-center small text-muted mt-4">
            Already have an account ?
            <a href="{{ path('app_login') }}" class="">
                Connexion
            </a>
        </p>


</div>

{% endblock %}

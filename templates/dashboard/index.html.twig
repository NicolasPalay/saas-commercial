{% extends 'base.html.twig' %}

{% block title %}Dashboard Dirigeant{% endblock %}

{% block body %}
<div class="d-flex w-100">

  {# ========== SIDEBAR OVERLAY (mobile) ========== #}
  <div class="sidebar-overlay" id="sidebarOverlay"></div>

  {# ========== SIDEBAR ========== #}
  <aside id="sidebar">
    <div class="sidebar-header">
      <button id="closeMenu" class="d-md-none">✕</button>
      <div>  
        <h2>
          <a href="{{ path('app_company_edit', {'id': user.company.id}) }}">{{ user.company.name }}</a>
        </h2>
        {% if user.company.urlLogo %}
          <img src="/uploads/{{ user.company.id }}/{{ user.company.urlLogo }}" alt="{{ user.company.name }}">
        {% endif %}
      </div>
    </div>

    <nav class="sidebar-nav">
      <a href="{{ path('app_employed') }}"><i class="bi bi-person-plus"></i> Ajouter un employé</a>
      <a href="{{ path('app_client_index') }}"><i class="bi bi-people"></i> Voir tous les clients</a>
      <a href="{{ path('app_client_new') }}"><i class="bi bi-person-plus"></i> Ajouter un client</a>
      <a href="{{ path('app_product_index') }}"><i class="bi bi-box-seam"></i> Voir les produits</a>
      <a href="#"><i class="bi bi-plus-square"></i> Ajouter un produit</a>
      <a href="{{ path('app_devis_index') }}"><i class="bi bi-file-text"></i> Voir tous les devis</a>
      <a href="#" class="openModal" data-action="click->modal#open"><i class="bi bi-plus-square"></i> Ajouter un devis</a>
      <a href="#"><i class="bi bi-receipt"></i> Voir toutes les factures</a>
      <a href="#"><i class="bi bi-plus-square"></i> Ajouter une facture</a>

      <hr>

      <div class="nav-section-title">Messagerie</div>
      {% for conversation in conversations %}
        <a href="{{ path('app_conversation_show', {'id': conversation.id}) }}">
          <i class="bi bi-chat-dots"></i> Conversation #{{ conversation.id }}
        </a>
      {% else %}
        <div style="padding: 8px 16px; color: var(--sky-shell); font-size: 13px;">Aucune conversation</div>
      {% endfor %}
    </nav>
  </aside>

  {# ========== MAIN CONTENT ========== #}
  <main class="w-100">

    {# Mobile top bar #}
    <div class="mobile-topbar">
      <button id="openMenu">☰</button>
      <h1>Dashboard</h1>
    </div>

       {# KPI Section #}
    <div class="row g-4 mb-4">
      <div class="col-6 col-lg-3">
        <div class="kpi-card">
          <p class="label">CA Mensuel (HT)</p>
          <h2 class="value">12 500 €</h2>
        </div>
      </div>
      <div class="col-6 col-lg-3">
        <div class="kpi-card">
          <p class="label">CA Annuel (HT)</p>
          <h2 class="value">152 000 €</h2>
        </div>
      </div>
      <div class="col-6 col-lg-3">
        <div class="kpi-card">
          <p class="label">Employés</p>
          <h2 class="value">{{ nEmployes }}</h2>
        </div>
      </div>
      <div class="col-6 col-lg-3">
        <div class="kpi-card">
          <p class="label">Clients actifs</p>
          <h2 class="value">120</h2>
        </div>
      </div>
    </div>

    {# Devis & Employees Section #}
    <div class="row g-4 mb-4">
      
      {# Latest Quotes #}
      <div class="col-lg-6">
        <div class="card-ocean">
          <div class="card-body">
            <h2 class="card-title-ocean">
              <i class="bi bi-file-text"></i>
              <a href="{{ path('app_devis_index') }}" style="color: var(--deep-marine); text-decoration: none;">3 derniers devis</a>
            </h2>
            <div class="table-responsive">
              <table class="table-ocean mb-0">
                <thead>
                  <tr>
                    <th>N°</th>
                    <th>Client</th>
                    <th>Montant HT</th>
                    <th>Date</th>
                  </tr>
                </thead>
                <tbody>
                  {% for devisOne in devis %}
                    <tr>
                      <td><a href="{{ path('app_devis_details_new', {'id': devisOne.id}) }}">{{ devisOne.reference }}</a></td>
                      <td><a href="{{ path('app_devis_details_new', {'id': devisOne.id}) }}">{{ devisOne.client.raisonSocial }}</a></td>
                      <td>{{ devisOne.total|number_format(2, ',', ' ') }} €</td>
                      <td>{{ devisOne.createdAt|date('d/m/Y') }}</td>
                    </tr>
                  {% endfor %}
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>

      {# Employee List #}
      <div class="col-lg-6">
        <div class="card-ocean">
          <div class="card-body">
            <div class="d-flex justify-content-between align-items-center mb-3">
              <h2 class="card-title-ocean mb-0">
                <i class="bi bi-people"></i> Liste des employés
              </h2>
              <div class="d-flex gap-2">
                <a href="{{ path('app_conversation_new') }}" class="btn-ocean btn-ocean-primary" style="padding: 8px 16px; font-size: 11px;">
                  <i class="bi bi-chat-dots"></i>
                </a>
                <a href="{{ path('app_employed') }}" class="btn-ocean btn-ocean-primary" style="padding: 8px 16px; font-size: 11px;">
                  <i class="bi bi-plus-square"></i>
                </a>
              </div>
            </div>
            <div>
              {% for employee in users %}
                <div class="employee-item">
                  <div class="email">{{ employee.email }}</div>
                  <div class="role">{{ employee.roles[0] }}</div>
                </div>
              {% else %}
                <p style="color: var(--dune); text-align: center; padding: 20px;">Aucun employé trouvé.</p>
              {% endfor %}
            </div>
          </div>
        </div>
      </div>
    </div>

    {# Recent Activity #}
    <div class="card-ocean mb-4">
      <div class="card-body">
        <h2 class="card-title-ocean">
          <i class="bi bi-clock-history"></i> Activité récente
        </h2>
        <div>
          <div class="activity-item">
            <span>Jean Dupont a créé un devis</span>
            <span>12/09/2025</span>
          </div>
          <div class="activity-item">
            <span>Marie Martin a ajouté un client</span>
            <span>10/09/2025</span>
          </div>
          <div class="activity-item">
            <span>Paul Leroy a modifié un produit</span>
            <span>08/09/2025</span>
          </div>
        </div>
      </div>
    </div>

    {# Internal Notes #}
    <div class="card-ocean mb-4">
      <div class="card-body">
        <h2 class="card-title-ocean">
          <i class="bi bi-journal-text"></i> Notes / Messages internes
        </h2>
        <textarea class="textarea-ocean" placeholder="Écrire une note ou un rappel pour l'équipe..."></textarea>
        <button class="btn-ocean btn-ocean-primary mt-3">
          <i class="bi bi-save"></i> Enregistrer
        </button>
      </div>
    </div>

    {# Financial Charts #}
    <div class="card-ocean mb-4">
      <div class="card-body">
        <h2 class="card-title-ocean">
          <i class="bi bi-graph-up"></i> Graphiques financiers
        </h2>
        <p style="color: var(--dune); margin-bottom: 12px;">Exemples :</p>
        <ul style="color: var(--dune); margin-bottom: 20px;">
          <li>Chiffre d'affaires mensuel vs annuel</li>
          <li>Top clients / produits</li>
          <li>Devis transformés vs refusés</li>
          <li>Répartition clients par secteur</li>
        </ul>
        <div class="chart-placeholder">
          Graphique placeholder
        </div>
      </div>
    </div>

    {# Financial Timeline #}
    <div class="card-ocean mb-4">
      <div class="card-body">
        <h2 class="card-title-ocean">
          <i class="bi bi-cash-coin"></i> Timeline financière
        </h2>
        <div>
          <div class="financial-item">
            <span>Facture #201 payée</span>
            <span class="amount-positive">+2 500 €</span>
          </div>
          <div class="financial-item">
            <span>Encaissement devis #102</span>
            <span class="amount-positive">+3 500 €</span>
          </div>
          <div class="financial-item">
            <span>Dépense fournisseur</span>
            <span class="amount-negative">-800 €</span>
          </div>
        </div>
      </div>
    </div>

  </main>
</div>
{% endblock %}

{% block javascripts %}
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script>
  // Mobile menu toggle
  const sidebar = document.getElementById('sidebar');
  const sidebarOverlay = document.getElementById('sidebarOverlay');
  const openMenu = document.getElementById('openMenu');
  const closeMenu = document.getElementById('closeMenu');

  openMenu?.addEventListener('click', () => {
    sidebar.classList.add('show');
    sidebarOverlay.classList.add('show');
  });

  closeMenu?.addEventListener('click', () => {
    sidebar.classList.remove('show');
    sidebarOverlay.classList.remove('show');
  });

  sidebarOverlay?.addEventListener('click', () => {
    sidebar.classList.remove('show');
    sidebarOverlay.classList.remove('show');
  });
</script>
<script src="{{ asset('assets/js/modal.js') }}"></script>
{% endblock %}

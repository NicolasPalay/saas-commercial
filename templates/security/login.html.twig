{% extends 'base.html.twig' %}

{% block title %}Log in!{% endblock %}

{% block body %}
<div class="login-container">
  <div class="login-card">
    
    <div class="login-header">
      <div class="login-logo">🌊</div>
      <h1>Connexion</h1>
      <p>Accédez à votre espace de gestion</p>
    </div>

    <div class="wave-divider">
      <svg viewBox="0 0 520 30" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0,30 C70,2 150,30 260,15 C370,0 450,28 520,12 L520,30 Z" fill="#fff"/>
      </svg>
    </div>

    <div class="login-body">
      
      {% if error %}
      <div class="alert-ocean error">
        ⚠ {{ error.messageKey|trans(error.messageData, 'security') }}
      </div>
      {% endif %}

      {% if app.user %}
      <div class="alert-ocean success">
        ✓ Vous êtes connecté en tant que {{ app.user.email }}
      </div>
      {% endif %}

      <form method="post">
        
        <div class="form-group">
          <label for="username" class="form-label">Email</label>
          <input type="email" value="{{ last_username }}" name="email" id="inputEmail" class="form-control" autocomplete="email" required autofocus>
        </div>

        <div class="form-group">
          <label for="password" class="form-label">Mot de passe</label>
          <div class="password-toggle">
               <input type="password" name="password" id="inputPassword" class="form-control" autocomplete="current-password" required>
            <button type="button" class="password-toggle-btn" onclick="togglePassword()">👁</button>
          </div>
        </div>

        <div class="form-check">
          <input type="checkbox" id="remember_me" name="_remember_me">
          <label for="remember_me">Se souvenir de moi</label>
        </div>

        <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

        <button type="submit" class="btn-submit">Se connecter</button>

      </form>

      <div class="divider"></div>

      <div style="text-align: center;">
        <a href="{{ path('forgotten_password') }}" style="color: var(--cloudy-ocean); text-decoration: none; font-size: 13px;">
          Mot de passe oublié ?
        </a>
      </div>

    </div>

    <div class="login-footer">
      <p>Vous n'avez pas de compte ?</p>
      <a href="{{ path('app_register') }}">Créer un compte</a>
    </div>

  </div>
</div>

<script>
function togglePassword() {
  const passwordInput = document.getElementById('password');
  const type = passwordInput.type === 'password' ? 'text' : 'password';
  passwordInput.type = type;
}
</script>
{% endblock %}

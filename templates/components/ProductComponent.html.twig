<div {{ attributes }}>
    <div class="w-100 my-4">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-0">

                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0 w-100 table-ocean">
                        <thead class="table-light">
                            <tr>
                                {% for header in headers %}
                                    <th class="fw-semibold text-uppercase small header-{{ header }}">
                                        <div class="d-flex align-items-center">
                                            <span>{{ header }}</span>

                                            <span class="sort-icons d-flex flex-column ms-2">
                                                <button
                                                    class="sort-btn"
                                                    data-action="live#action"
                                                    data-live-action-param="sort"
                                                    data-live-header-param="{{ header }}"
                                                    data-live-direction-param="asc">
                                                    <i class="bi bi-caret-up-fill"></i>
                                                </button>

                                                <button
                                                    class="sort-btn"
                                                    data-action="live#action"
                                                    data-live-action-param="sort"
                                                    data-live-header-param="{{ header }}"
                                                    data-live-direction-param="desc">
                                                    <i class="bi bi-caret-down-fill"></i>
                                                </button>
                                            </span>
                                        </div>
                                    </th>
                                {% endfor %}
                            </tr>
                        </thead>

                        <tbody>
 
                            {% for product in lines %}
                                <tr class="table-row">
                                    <td>
                                        <a href="{{ path('app_product_edit', {'id': product.id}) }}"
                                           >
                                            {{ product.reference }}
                                        </a>
                                    </td>

                                    <td><a href="{{ path('app_product_edit', {'id': product.id}) }}"
                                           >{{ product.name }}</a></td>

                                    <td class="text-right">
                                        {{ product.price | number_format(2, ',', ' ') }} €
                                    </td>

                                    <td class="text-muted">
                                        {{ product.createdAt|date('d/m/Y ') }}
                                    </td>
                                </tr>
                            {% else %}
                                <tr>
                                    <td colspan="{{ headers|length }}" class="text-center py-4 text-muted">
                                        Aucun produit pour le moment
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>

            </div>
        </div>
    </div>
</div>

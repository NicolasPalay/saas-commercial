{% extends 'base.html.twig' %}

{% block title %}New Message{% endblock %}

{% block body %}
    <h1>Create new Message</h1>

<div class="min-h-screen flex items-center justify-center bg-gradient-to-br from-purple-600 to-indigo-700 px-4">

    <div class="w-full max-w-3xl bg-white rounded-3xl shadow-2xl p-10">

        <h1 class="text-3xl font-bold text-center text-gray-800 mb-10 p-10">
            Nouveau employé
        </h1>
<form hx-post="{{ path('message.create') }}"
 method="post" hx-trigger="change submit" hx-target="this" hx-swap="outerHTML" novalidate
        >
    <div class="relative">
            <span class="absolute inset-y-0 left-0 flex items-center pl-5 text-purple-600">
                🏢
            </span>
            <input type="hidden" name="_token" value="{{ csrf_token('message_create') }}">
           <input
                type="text"
                aria-label="content"
                id="content"
                name="content"
                class='w-full pl-14 pr-6 py-4 rounded-full border border-gray-200 text-purple-600 shadow-sm focus:ring-2 focus:ring-purple-500 focus:outline-none',
                placeholder='message'
            >
            <input
                type="hidden"
                
                id="conversationId"
                name="conversationId"
                class='w-full pl-14 pr-6 py-4 rounded-full border border-gray-200 text-purple-600 shadow-sm focus:ring-2 focus:ring-purple-500 focus:outline-none',
                value= {{conversation.id}}
            >
        </div>
        <div class="flex justify-between items-center pt-8">
            <button
                type="submit"
                class="px-10 py-4 rounded-full text-white font-semibold bg-gradient-to-r from-purple-600 to-indigo-600 hover:opacity-90 transition shadow-xl"
            >
                Enregistrer
            </button>

        </div>


    
    </div>
</div>
</form>
{% endblock %}

<div class="card-ocean">
  {# Header avec infos du devis #}
  <div class="card-ocean-header" style="padding: 32px 40px;">
    <h1 style="color: var(--white); font-size: 24px; margin-bottom: 8px; text-align: center;">
      <a href="{{ path('app_devis_edit', {'id': devis.id}) }}" style="color: var(--white); text-decoration: none;">
        Devis n°{{ devis.reference }}
      </a>
    </h1>
    <p style="color: var(--sky-shell);" class="text-center mb-25">
      {{ devis.deliveryLabel }}
    </p>
      {# Bouton retour vers l'édition du devis #}
    <div class="text-center mb-4">
      <a href="{{ path('app_devis_edit', {'id': devis.id}) }}" class="btn-ocean btn-ocean-secondary btn-ocean-sm">
        <i class="bi bi-pencil"></i> Modifier l'adresse
      </a>
    </div>

  </div>
  <div class="card-ocean-body">
    
  
    <div class="divider"></div>

    {# Tableau des lignes de devis #}
    <div class="table-card mb-4">
      <div class="table-responsive">
        <table class="table-ocean">
          <thead>
            <tr>
              <th>Réf. Prod</th>
              <th>Nom du Produit</th>
              <th>Qté</th>
              <th>Prix Unit</th>
              <th>Remise</th>
              <th>Total</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            {% for devisLine in devis.devisDetails %}
              <tr>
                <td>
                  <a href="{{ path('app_devis_details_edit', {'id': devisLine.id}) }}">
                    {{ devisLine.product.reference }}
                  </a>
                </td>
                <td>
                  <a href="{{ path('app_devis_details_edit', {'id': devisLine.id}) }}">
                    {{ devisLine.label }}
                  </a>
                </td>
                <td>{{ devisLine.quantity }}</td>
                <td>{{ devisLine.price | number_format(2, ',', ' ') }} €</td>
                <td>{{ devisLine.reduce | number_format(2, ',', ' ') }} %</td>
                <td><strong>{{ devisLine.total | number_format(2, ',', ' ') }} €</strong></td>
                <td>
                  {{ include('devis_details/_delete_form.html.twig', { devis_detail: devisLine }) }}
                </td>
              </tr>
            {% else %}
              <tr>
                <td colspan="7" style="text-align: center; padding: 40px; color: var(--dune);">
                  <i class="bi bi-inbox" style="font-size: 48px; display: block; margin-bottom: 12px; opacity: 0.5;"></i>
                  Aucune ligne de devis
                </td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    </div>

    

    {# Formulaire d'ajout/édition #}
    <div class="bg-light p-4 form-edit-detail-devis editAbsolute" style="border-radius: var(--radius-lg); border: 1.5px solid var(--sky-shell);">
      </h3>
{{ form_start(form) }}
        {{ form_widget(form) }}
        <button class="btn-ocean btn-ocean-secondary btn-ocean-sm" type="submit"
    >{{ button_label|default('Sélectionnez') }}</button>
    {{ form_end(form) }}
    </div>
<div class="divider"></div>
  </div>
</div>

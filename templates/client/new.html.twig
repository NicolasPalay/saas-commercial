{% extends 'base.html.twig' %}

{% block title %}Nouveau client{% endblock %}

{% block body %}
<div class="min-h-screen flex items-center justify-center bg-gradient-to-br from-purple-600 to-indigo-700 px-4">

    <div class="w-full max-w-3xl bg-white rounded-3xl shadow-2xl p-10">

        <h1 class="text-3xl font-bold text-center text-gray-800 mb-10 p-10">
            Nouveau client
        </h1>

        {{ form_start(form, { attr: { class: 'space-y-6' } }) }}

        {# RAISON SOCIALE #}
        <div class="relative">
            <span class="absolute inset-y-0 left-0 flex items-center pl-5 text-purple-600">
                🏢
            </span>
            {{ form_widget(form.raison_social, {
                attr: {
                    class: 'w-full pl-14 pr-6 py-4 rounded-full border border-gray-200 text-purple-600 shadow-sm focus:ring-2 focus:ring-purple-500 focus:outline-none',
                    placeholder: 'Raison sociale'
                }
            }) }}
            {{ form_errors(form.raison_social) }}
        </div>

        {# ADRESSE #}
        <div class="relative">
            <span class="absolute inset-y-0 left-0 flex items-center pl-5 text-purple-600">
                📍
            </span>
            {{ form_widget(form.nameStreet, {
                attr: {
                    class: 'w-full pl-14 pr-6 py-4 rounded-full border border-gray-200 text-purple-600 shadow-sm focus:ring-2 focus:ring-purple-500 focus:outline-none',
                    placeholder: 'Adresse'
                }
            }) }}
        </div>

        {# COMPLEMENT ADRESSE #}
        <div class="relative">
            <span class="absolute inset-y-0 left-0 flex items-center pl-5 text-purple-600">
                ➕
            </span>
            {{ form_widget(form.nameStreet2, {
                attr: {
                    class: 'w-full pl-14 pr-6 py-4 rounded-full border border-gray-200 text-purple-600 shadow-sm focus:ring-2 focus:ring-purple-500 focus:outline-none',
                    placeholder: 'Complément d’adresse'
                }
            }) }}
        </div>

        {# CODE POSTAL + VILLE #}
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

            <div class="relative">
                <span class="absolute inset-y-0 left-0 flex items-center pl-5 text-purple-600">
                    📮
                </span>
                {{ form_widget(form.codePostal, {
                    attr: {
                        class: 'w-full pl-14 pr-6 py-4 rounded-full border border-gray-200 text-purple-600 shadow-sm focus:ring-2 focus:ring-purple-500 focus:outline-none',
                        placeholder: 'Code postal'
                    }
                }) }}
            </div>

            <div class="relative">
                <span class="absolute inset-y-0 left-0 flex items-center pl-5 text-purple-600">
                    🏙️
                </span>
                {{ form_widget(form.ville, {
                    attr: {
                        class: 'w-full pl-14 pr-6 py-4 rounded-full border border-gray-200 text-purple-600 shadow-sm focus:ring-2 focus:ring-purple-500 focus:outline-none',
                        placeholder: 'Ville'
                    }
                }) }}
            </div>

        </div>

        {# TELEPHONES #}
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

            <div class="relative">
                <span class="absolute inset-y-0 left-0 flex items-center pl-5 text-purple-600">
                    ☎️
                </span>
                {{ form_widget(form.businessPhone, {
                    attr: {
                        class: 'w-full pl-14 pr-6 py-4 rounded-full border border-gray-200 text-purple-600 shadow-sm focus:ring-2 focus:ring-purple-500 focus:outline-none',
                        placeholder: 'Téléphone fixe'
                    }
                }) }}
            </div>

            <div class="relative">
                <span class="absolute inset-y-0 left-0 flex items-center pl-5 text-purple-600">
                    📱
                </span>
                {{ form_widget(form.mobilePhone, {
                    attr: {
                        class: 'w-full pl-14 pr-6 py-4 rounded-full border border-gray-200 text-purple-600 shadow-sm focus:ring-2 focus:ring-purple-500 focus:outline-none',
                        placeholder: 'Téléphone mobile'
                    }
                }) }}
            </div>

        </div>

        {# EMAIL #}
        <div class="relative">
            <span class="absolute inset-y-0 left-0 flex items-center pl-5 text-purple-600">
                ✉️
            </span>
            {{ form_widget(form.email, {
                attr: {
                    class: 'w-full pl-14 pr-6 py-4 rounded-full border border-gray-200 text-purple-600 shadow-sm focus:ring-2 focus:ring-purple-500 focus:outline-none',
                    placeholder: 'Email'
                }
            }) }}
        </div>

        {# ACTIONS #}
        <div class="flex justify-between items-center pt-8">

            <a href="{{ path('app_client_index') }}"
               class="text-sm text-gray-500 hover:underline">
                ← Retour
            </a>

            <button
                type="submit"
                class="px-10 py-4 rounded-full text-white font-semibold bg-gradient-to-r from-purple-600 to-indigo-600 hover:opacity-90 transition shadow-xl"
            >
                Enregistrer
            </button>

        </div>

        {{ form_end(form) }}

    </div>
</div>
{% endblock %}
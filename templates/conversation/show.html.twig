{% extends 'base.html.twig' %}

{% block title %}Conversation{% endblock %}

{% block body %}
<div class="min-h-screen flex items-center justify-center bg-gradient-to-br from-purple-600 to-indigo-700 px-4">

    <div class="w-full max-w-3xl bg-white rounded-3xl shadow-2xl p-10">

        <h1 class="text-3xl font-bold text-center text-gray-800 mb-10 p-10">
            Conversation
        </h1>

        <section 
            class="flex flex-col items-start p-6 overflow-y-auto h-[70vh]"
            hx-ext="sse"
            sse-connect="{{ mercure(topicUrl) }}"
            sse-swap="message"
        >
            {% include('message/index.html.twig') %}
        </section>
<form 
    hx-post="{{ path('message.create')}}" 
    hx-headers='{"Content-Type": "application/json"}'
    hx-encoding="json"
    hx-swap="none"
>
<div class="relative">
            <span class="absolute inset-y-0 left-0 flex items-center pl-5 text-purple-600">
                🏢
            </span>
             <input
            type="text"
            name="content"
            placeholder="message"
            class="w-full pl-14 pr-6 py-4 rounded-full border border-gray-200 text-purple-600 shadow-sm focus:ring-2 focus:ring-purple-500 focus:outline-none"
        >

        <input
            type="hidden"
            name="conversationId"
            value="{{ conversation.id }}"
        >
        </div>
        <div class="flex justify-between items-center pt-8">
            <button
                type="submit"
                class="px-10 py-4 rounded-full text-white font-semibold bg-gradient-to-r from-purple-600 to-indigo-600 hover:opacity-90 transition shadow-xl"
            >
                Enregistrer
            </button>

        </div>

    
    </div>
</div>
</form>
{% endblock %}
    {% block javascripts %}
    <script>
    const messages = document.querySelector('section');
    const UserId = '{{ app.user.id }}';
    document.addEventListener('DomContentLoaded', () => {
        scrollToButtom(messages);
    });

    document.body.addEventListener(htmx;sseBeforeMessage, function (e) {
        e.preventDefault();

        const json = e.detail.data;
    });
    function scrollToButtom(element) {
        element.scrollTo(top: element.scrollHeight,
        behavior: 'smooth');
    }
    </script>
    {% endblock %}

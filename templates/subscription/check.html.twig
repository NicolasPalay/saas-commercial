{% extends 'base.html.twig' %}

{% block title %}Hello SubscriptionController!{% endblock %}

{% block body %}
<div class="text-center w-100">
    
   {% for message in app.flashes('info') %}

            <div class="bg-info-subtle rounded-lg p-4 mb-4 flash-message" role="alert">
                {{ message }}
            </div>

    {% endfor %}

    <section class="pricing-section abonnez-vous mb-5 px-5" id="tarifs">
        <div class="container  my-5">
            <h1 class="section-title text-white">Vos abonnements récapitulatifs</h1>
            
            <div class="row justify-content-evenly">

                {% if subscriptions %}
                    {% for subscription in subscriptions %}
                        <div class="col-lg-4 pricing-card d-flex flex-column justify-content-between">
                            <div>
                                <h3>{{ subscription.type }}</h3>
                                <div class="price">{{ subscription.montant }}€ HT<span>/mois</span></div>
                            </div>
                           
                            {% if subscription.isPay %}
                                <a href="" class="btn btn-primary w-100">abonnement actuel</a>
                            {% else %}
                             <form action="{{path('app_payment_stripe')}}" method="POST">
                                <!-- Add a hidden field with the lookup_key of your Price -->
                                <input type="hidden" name="lookup_key" value="{{ subscription.stripeId }}" />
                                <button id="checkout-and-portal-button" type="submit">Checkout</button>
                            </form>
                            {% endif %}
                               
                        </div>
                    {% endfor %}
                {% endif %}

            </div>

        </div>
    </section>
</div>
{% endblock %}
